# Application
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chefer_dev

# Auth / JWT
JWT_SECRET=your-super-secret-jwt-key-here-min-32-chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your-refresh-token-secret-here-min-32-chars
REFRESH_TOKEN_EXPIRES_IN=30d

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ── AI (PersonalChef) ─────────────────────────────────────────────────────────
# Set AI_MOCK_ENABLED=true locally — no real LLM calls, no token spend.
# Set AI_MOCK_ENABLED=false only in production after setting an API key below.
AI_MOCK_ENABLED=true
AI_MOCK_DELAY_MS=0
AI_PROVIDER=openai

# Only required when AI_MOCK_ENABLED=false
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Email (Phase 4) ───────────────────────────────────────────────────────────
# Leave blank locally — email is silently skipped when key is absent.
RESEND_API_KEY=

# ── Stripe (Phase 5) ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
