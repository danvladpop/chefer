# Application
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chefer_dev

# Auth / JWT
JWT_SECRET=your-super-secret-jwt-key-here-min-32-chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your-refresh-token-secret-here-min-32-chars
REFRESH_TOKEN_EXPIRES_IN=30d

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ── AI (Chefer) ───────────────────────────────────────────────────────────────
# Set AI_MOCK_ENABLED=true locally — no real LLM calls, no token spend.
# Set AI_MOCK_ENABLED=false to use a real AI provider (set the key below too).
AI_MOCK_ENABLED=true
AI_MOCK_DELAY_MS=0

# Which provider to use when AI_MOCK_ENABLED=false.
# Options: gemini | openai | anthropic
AI_PROVIDER=gemini

# Gemini (free tier — get key at https://aistudio.google.com)
# Required when AI_PROVIDER=gemini
GEMINI_API_KEY=

# OpenAI — required when AI_PROVIDER=openai
OPENAI_API_KEY=

# Anthropic — required when AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# ── Email (Phase 4) ───────────────────────────────────────────────────────────
# Leave blank locally — email is silently skipped when key is absent.
RESEND_API_KEY=

# ── Stripe (Phase 5) ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
