{
  "name": "@chefer/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/routers/index.ts",
      "import": "./src/routers/index.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch --clear-screen=false --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@chefer/database": "workspace:*",
    "@chefer/types": "workspace:*",
    "@chefer/utils": "workspace:*",
    "@google/genai": "^1.47.0",
    "@trpc/server": "^11.0.0-rc.446",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "superjson": "^2.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@chefer/tsconfig": "workspace:*",
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "tsx": "^4.16.0",
    "typescript": "^5.5.2",
    "vitest": "^1.6.0"
  }
}
