# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=PersonalChef.ai
NODE_ENV=development

# API / tRPC
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_TRPC_URL=http://localhost:3001/trpc

# Session (used for signing share-link JWTs in Phase 4)
SESSION_SECRET=your-session-secret-here-min-32-chars

# Cloudinary (optional — images currently served from Unsplash CDN)
# After running `pnpm upload:images`, set your cloud name here.
# The upload script reads CLOUDINARY_API_KEY / CLOUDINARY_API_SECRET from apps/api/.env
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
