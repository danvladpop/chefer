# ─────────────────────────────────────────────────────────────────────────────
# PersonalChef.ai — Root Environment Variables Reference
# Copy relevant sections into apps/api/.env and apps/web/.env.local
# ─────────────────────────────────────────────────────────────────────────────

# ── Shared ────────────────────────────────────────────────────────────────────
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chefer_dev

# ── API (apps/api/.env) ───────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0

JWT_SECRET=your-super-secret-jwt-key-here-min-32-chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your-refresh-token-secret-here-min-32-chars
REFRESH_TOKEN_EXPIRES_IN=30d

CORS_ORIGINS=http://localhost:3000,http://localhost:3001

RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# AI — keep AI_MOCK_ENABLED=true locally; set false only in production
AI_MOCK_ENABLED=true
AI_MOCK_DELAY_MS=0
AI_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Email — leave blank locally (silently skipped); set in production (Phase 4)
RESEND_API_KEY=

# Stripe — leave blank locally (Phase 5)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Web (apps/web/.env.local) ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=PersonalChef.ai
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_TRPC_URL=http://localhost:3001/trpc

# Used server-side for signing share-link JWTs (Phase 4)
SESSION_SECRET=your-session-secret-here-min-32-chars
