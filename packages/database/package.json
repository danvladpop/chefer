    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "tsx src/seed.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@chefer/types": "workspace:*",
    "@prisma/client": "^5.16.0",
    "bcryptjs": "^3.0.3"
  },
  "devDependencies": {
    "@chefer/tsconfig": "workspace:*",
    "@types/bcryptjs": "^3.0.0",
    "prisma": "^5.16.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.2"
  }
